generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id         String   @id @default(uuid())
  parentName String
  childAge   Int
  phone      String
  status     String   @default("Новая") // "Новая" или "Обработана"
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

model Photo {
  id        String   @id @default(uuid())
  url       String
  createdAt DateTime @default(now())
}

model Student {
  id        String          @id @default(uuid())
  name      String
  age       Int?
  phone     String?
  tag       String          @default("Индивидуальное")
  notes     String?
  photoUrl  String?
  createdAt DateTime        @default(now())
  lessons   LessonStudent[]
  parents   ParentStudent[]

  @@index([tag])
}

model Lesson {
  id        String          @id @default(uuid())
  date      DateTime
  title     String?
  tag       String          @default("Индивидуальное")
  notes     String?
  homework  String?
  price     Float?
  students  LessonStudent[]
  files     LessonFile[]
  createdAt DateTime        @default(now())

  @@index([date])
}

model LessonFile {
  id        String   @id @default(uuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  url       String
  name      String
  size      Int
  createdAt DateTime @default(now())

  @@index([lessonId])
}

model LessonStudent {
  lessonId  String
  studentId String
  attended  Boolean @default(false)
  grade     Int?
  comment   String?
  lesson    Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([lessonId, studentId])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
}

model TeacherProfile {
  id       String  @id @default("singleton")
  name     String  @default("Анна Сергеевна")
  bio      String  @default("Сертифицированный преподаватель английского языка с опытом 7 лет. Специализируется на обучении детей от 6 до 14 лет — в игровой форме, без скучной зубрёжки. Каждый ребёнок уходит с занятия с улыбкой и новыми знаниями.")
  photoUrl String?
  badges   String  @default("Сертификат CELTA,Опыт 7 лет,IELTS 8.0,Дети 6–14 лет")
}

model SiteSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Post {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  isPublished Boolean   @default(false)
  category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished])
  @@index([categoryId])
  @@index([createdAt])
}

model LibraryFile {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String
  name        String
  size        Int
  category    String?
  targetTag   String   @default("Все")
  createdAt   DateTime @default(now())

  @@index([targetTag])
}

// ─── Auth & Roles ────────────────────────────────────────────────────────────

enum Role {
  TEACHER
  PARENT
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(PARENT)
  parent       Parent?
  createdAt    DateTime @default(now())

  @@index([username])
}

model Parent {
  id        String          @id @default(uuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  email     String?
  students  ParentStudent[]
  createdAt DateTime        @default(now())
}

model ParentStudent {
  parentId  String
  studentId String
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
}
